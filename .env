# Default is mediapipe so the project can run without compiling OpenPose.
POSE_BACKEND=mediapipe

# Expo web uses this from the browser, so localhost means the host machine.
EXPO_PUBLIC_POSE_API_URL=http://localhost:8000

# none | vrm | mmd
EXPO_PUBLIC_AVATAR_MODE=vrm

# Place this file at frontend/public/models/avatar.vrm
EXPO_PUBLIC_VRM_URL=/models/avatar.vrm

# Place this file at frontend/public/models/model.pmx
EXPO_PUBLIC_MMD_URL=/models/model.pmx
